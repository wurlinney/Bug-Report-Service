APP_ENV=production
HTTP_ADDR=:8080
LOG_LEVEL=info

CORS_ALLOWED_ORIGINS=https://your-domain.example

RATE_LIMIT_RPS=10
RATE_LIMIT_BURST=20

# HTTP timeouts
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s

# DB 
DATABASE_URL=postgres://bug:change-me@postgres:5432/bugdb?sslmode=disable

POSTGRES_USER=bug
POSTGRES_PASSWORD=change-me
POSTGRES_DB=bugdb
POSTGRES_PORT=5432

# JWT
JWT_ISSUER=bug-report-service
JWT_SECRET=change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# S3 / MinIO
S3_ENDPOINT=http://minio:9000
# Публичный endpoint для браузера
S3_PUBLIC_ENDPOINT=https://minio.your-domain.example
S3_REGION=us-east-1
S3_BUCKET=bug-attachments

S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-me

# Tus cleanup 
TUS_CLEANUP_ENABLED=true
TUS_CLEANUP_OBJECT_PREFIX=tus/
TUS_CLEANUP_GRACE_PERIOD=6h
TUS_CLEANUP_INTERVAL=30m

# Ports
HTTP_PORT=8080
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Moderator seed (до 5 модераторов)
MOD_SEED_1_EMAIL=mod1@example.com
MOD_SEED_1_NAME=Moderator 1
MOD_SEED_1_PASSWORD=change-me-1

MOD_SEED_2_EMAIL=mod2@example.com
MOD_SEED_2_NAME=Moderator 2
MOD_SEED_2_PASSWORD=change-me-2

MOD_SEED_3_EMAIL=
MOD_SEED_3_NAME=
MOD_SEED_3_PASSWORD=

MOD_SEED_4_EMAIL=
MOD_SEED_4_NAME=
MOD_SEED_4_PASSWORD=

MOD_SEED_5_EMAIL=
MOD_SEED_5_NAME=
MOD_SEED_5_PASSWORD=
